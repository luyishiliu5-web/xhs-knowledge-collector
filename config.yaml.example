# 小红书内容采集 - 配置文件示例
# 复制为 config.yaml 后修改

# Chrome 浏览器路径
chrome_path: "/home/xiaohuang2/.cache/ms-playwright/chromium-1223/chrome-linux64/chrome"

# Chrome 用户数据目录（持久化登录态）
user_data_dir: "./user_data"

# WSL 环境必须设为 true（没有 X Server）
headless: true

# LLMWiki 知识库输出目录
knowledge_base_dir: "./knowledge_base"

# 采集行为控制
behavior:
  min_delay: 3
  max_delay: 8
  scroll_delay_min: 1.5
  scroll_delay_max: 4.0
  scroll_step_min: 300
  scroll_step_max: 800

# 请求频率控制
rate_limit:
  min_interval: 30
  max_daily: 20

# 采集内容
collect:
  comments: true
  max_comments: 50
  images: false

# 视频采集
video:
  download: true
  max_size_mb: 500
  download_dir: "./videos"
  formats: ["mp4"]
  quality: "highest"

# 语音转文字 (ASR)
asr:
  enabled: true
  # 模型: tiny | base | small | medium | large
  # - base: 速度优先（推荐，中文质量尚可）
  # - small: 质量优先（推荐，中文效果好，CPU 可接受）
  whisper_model: "base"
  whisper_language: "zh"
  max_audio_seconds: 3600
  use_api_fallback: false

# 反检测
anti_detection:
  pass
